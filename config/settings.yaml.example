# 主配置文件模板。复制为 settings.yaml 并填入 api_key 等。
# config/settings.yaml 已加入 .gitignore，请勿提交含密钥的文件。

llm:
  provider: deepseek
  model: deepseek-chat
  api_key: ""          # 或使用环境变量
  base_url: https://api.deepseek.com

embedding:
  provider: openai
  model: text-embedding-3-small

vector_store:
  provider: chroma
  persist_directory: data/chroma

retrieval:
  top_k: 10
  rerank_top_m: 20

rerank:
  provider: none

splitter:
  provider: recursive
  chunk_size: 512
  chunk_overlap: 50

evaluation:
  provider: ragas

observability:
  log_level: INFO
  traces_path: logs/traces.jsonl
