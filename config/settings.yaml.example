# 主配置文件模板。复制为 settings.yaml 并填入 api_key 等。
# config/settings.yaml 已加入 .gitignore，请勿提交含密钥的文件。

llm:
  provider: deepseek
  model: deepseek-chat
  api_key: ""          # 或使用环境变量
  base_url: https://api.deepseek.com

embedding:
  provider: openai
  model: text-embedding-3-small
# 使用 Qwen（阿里云百炼 DashScope）文本向量，可与 vision_llm 共用同一 API Key：
# embedding:
#   provider: qwen
#   model: text-embedding-v3      # 或 text-embedding-v4
#   api_key: ""                  # DashScope API Key
#   base_url: https://dashscope.aliyuncs.com/compatible-mode/v1   # 可选，不填则用默认

vector_store:
  provider: chroma
  persist_directory: data/chroma

retrieval:
  top_k: 10
  rerank_top_m: 20

rerank:
  provider: none

splitter:
  provider: recursive
  chunk_size: 512
  chunk_overlap: 50

evaluation:
  provider: ragas

# Vision LLM（可选）：Transform 阶段 ImageCaptioner 用其做 PDF 图转文（语意识别）。
# 未配置时，含图片的 chunk 不会调多模态接口，仅标记 has_unprocessed_images。
# 支持 provider: qwen（Qwen-VL-Max / DashScope）、azure、deepseek。
# 使用 Qwen-VL-Max（推荐，DashScope OpenAI 兼容模式）：
# vision_llm:
#   provider: qwen
#   api_key: ""                    # 阿里云百炼 / DashScope API Key
#   base_url: https://dashscope.aliyuncs.com/compatible-mode/v1
#   model: qwen-vl-max             # 或 qwen-vl-max-latest
#   max_image_size: 2048
# 使用 DeepSeek 示例：
# vision_llm:
#   provider: deepseek
#   api_key: ""
#   base_url: https://api.deepseek.com
#   model: deepseek-chat
#   max_image_size: 2048
# 使用 Azure 示例：
# vision_llm:
#   provider: azure
#   api_key: ""
#   azure_endpoint: https://xxx.openai.azure.com
#   api_version: "2024-02-15-preview"
#   deployment_name: gpt-4o
#   max_image_size: 2048

observability:
  log_level: INFO
  traces_path: logs/traces.jsonl
